# Spec-Driven LLM Wiki configuration.
# Core deterministic tools work without any LLM key.

# Optional LLM inference for semantic graph edges.
LLM_API_KEY=
LLM_MODEL=claude-sonnet-4-20250514
LLM_BASE_URL=
LLM_MODEL_FAST=claude-3-5-haiku-latest

# Graph behavior.
GRAPH_INFER_ENABLED=false
GRAPH_CACHE_ENABLED=true
COMMUNITY_DETECTION=both

# Project detection.
# Default is the parent folder of spec-driven-llm-wiki.
PROJECT_ROOT=..

# Dynamic tool directory.
TOOLS_ADDITIONAL_DIR=tools/additional
