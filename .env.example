HOST=127.0.0.1
PORT=30000
DEFAULT_PROVIDER=minimax
DEFAULT_MODEL=MiniMax-M2.7
MINIMAX_API_KEY=your-minimax-api-key-here
MINIMAX_BASE_URL=https://api.minimax.io/anthropic/v1
LOG_LEVEL=info
LOG_FORMAT=text
LOG_DIR=logs
LOG_INCLUDE_CONTENT=true
THINKING_PIPELINE_ENABLED=true
THINKING_STEP_COUNT=10
THINKING_RETURN_MODE=final
TRAINING_TRACE_ENABLED=true